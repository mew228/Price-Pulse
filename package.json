{
  "name": "pricepulse",
  "version": "1.0.0",
  "description": "Smart price drop tracker for Amazon, Flipkart, and Myntra",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev:server": "nodemon server/server.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "mongodb": "^7.1.1",
    "mongoose": "^8.2.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "twilio": "^5.0.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
